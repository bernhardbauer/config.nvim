{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["amazon-bedrock", "openai"],
  "model": "amazon-bedrock/eu.anthropic.claude-sonnet-4-6",
  "small_model": "amazon-bedrock/eu.anthropic.claude-haiku-4-5-20251001-v1:0",
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "eu-central-1",
        "profile": "default"
      }
    }
  },
  "share": "disabled",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": {
      "~/git/**": "deny",
      "~/.config/neovim/**": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "*": "ask",
      "git commit *": "deny",
      "git tag *": "deny",
      "git push *": "deny",
      "rm *": "deny",
      "npm run *": "allow",
      "npx tsc *": "allow",
      "npx eslint *": "allow",
      "npx vitest run *": "allow",
      "npx playwright test *": "allow",
      "bun run *": "allow",
      "bunx tsc *": "allow",
      "bunx eslint *": "allow",
      "bunx vitest run *": "allow",
      "bunx playwright test *": "allow",
      "dotnet run *": "allow",
      "git diff *": "allow",
      "git grep *": "allow",
      "git log *": "allow",
      "git shortlog *": "allow",
      "git show *": "allow",
      "git stash *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "ls *": "allow",
      "find *": "allow"
    },
    "task": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "external_directory": {
      "~/git/**": "allow",
      "~/.config/neovim/**": "allow"
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "out/**",
      "out-tsc/**",
      ".git/**",
      ".cache/**",
      ".angular/**",
      "*/obj/**",
      "*/bin/**"
    ]
  }
}
